# ===== Indodax API =====
INDODAX_API_KEY=your_indodax_api_key
INDODAX_SECRET=your_indodax_secret


# ===== Trading Configuration =====
TRADING_MODE=paper
TRADING_PAIRS=BTC/IDR,ETH/IDR,SOL/IDR
TIMEFRAME=1h
ANALYSIS_INTERVAL_MINUTES=60

# ===== Risk Management =====
RISK_PER_TRADE=0.02
MAX_OPEN_POSITIONS=3
DAILY_DRAWDOWN_LIMIT=0.05
STOP_LOSS_ATR_MULTIPLIER=1.5
TAKE_PROFIT_RR_RATIO=2.0

# ===== Volume Anomaly Tracker =====
VOLUME_ANOMALY_MULTIPLIER=3.0
VOLUME_ANOMALY_MIN_USD_VALUE=5000
VOLUME_POLL_INTERVAL_MINUTES=10

# ===== Logging =====
LOG_LEVEL=INFO
LOG_DIR=logs
CRYPTOPANIC_API_KEY=""
